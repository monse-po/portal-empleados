# Neon Postgres (producción / remoto) — generado con `neon env pull`
DATABASE_URL="postgresql://..."
DATABASE_URL_UNPOOLED="postgresql://..."
NEON_BRANCH="production"
NEON_AUTH_BASE_URL="https://..."
NEON_AUTH_JWKS_URL="https://..."

# SQLite local (opcional, sin Neon)
# DATABASE_URL="file:./prisma/dev.db"

# IFS — CEmpPortalServices (Hoja de tiempo, copiar valores reales a .env.local)
IFS_CEMP_PORTAL_BASE_URL=https://hmvdev.ifs360.cloud/int/ifsapplications/projection/v1/CEmpPortalServices.svc
IFS_OPENID_CONFIG_URL=https://hmvdev.ifs360.cloud/auth/realms/hmvdev/.well-known/openid-configuration

# Oracle IDCS / IAM client (mismos valores que IFS Solution Manager)
IFS_IDCS_CLIENT_ID=
IFS_IDCS_CLIENT_SECRET=
IFS_IDCS_DOMAIN_URL=https://idcs-….identity.oraclecloud.com:443
# Token endpoint (auto: IDCS si hay IFS_IDCS_DOMAIN_URL, si no realm hmvdev)
# IFS_OAUTH_TOKEN_URL=
# Scope (auto: urn:opc:idm:__myscopes__ en IDCS | openid microprofile-jwt en realm IFS)
# IFS_OAUTH_SCOPE=
# EmailId en CEmpPortalUserSet para scripts de prueba
# IFS_PORTAL_TEST_EMAIL=empleado@hmv.com

# Login OAuth empleado (IFS_EMP_PORTAL_USER) — off por defecto
# IFS_AUTH_ENABLED=true
# IFS_OAUTH_CLIENT_ID=IFS_EMP_PORTAL_USER
# IFS_OAUTH_CLIENT_SECRET=
# IFS_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback/ifs
# IFS_USE_REALM_OAUTH=true
# IFS_SESSION_SECRET=genera-un-string-largo-aleatorio
